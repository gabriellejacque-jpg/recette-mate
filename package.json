{
  "name": "recette-mate",
  "version": "1.0.0",
  "type": "module",
  "description": "Carnet de recettes : saisie manuelle + import depuis Instagram",
  "scripts": {
    "dev": "concurrently -k -n VITE,API -c cyan,magenta \"vite\" \"API_PORT=3001 node server/index.js\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "serve": "npm run build && npm run start"
  },
  "dependencies": {
    "@netlify/blobs": "^8.1.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@netlify/zip-it-and-ship-it": "^15.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.2"
  }
}
